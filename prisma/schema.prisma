generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model School {
  id            Int      @id @default(autoincrement())
  keyword       String   @unique
  name          String
 
  logo_data_url String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
 
  documents            Document[]
  users                User[]
  school_class_subject SchoolClassSubject[]
}
 
 
model Board {
  id   Int    @id @default(autoincrement())
  name String @unique // e.g. "SSC", "NCERT"
 
  subjects Subject[]
}
model Class {
  id   Int    @id @db.SmallInt
  name String @unique
 
  class_subject ClassSubject[]
}
 
model Chapter{
  id Int @id @default(autoincrement())
  book_id Int
  title String
  order_no Int?
  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)
  topics Topic[]
  @@index([book_id])
}
 
model Subject {
  id        Int     @id @default(autoincrement())
  board_id  Int
  name      String
  is_active Boolean @default(true)
 
  board         Board          @relation(fields: [board_id], references: [id], onDelete: Cascade)
  class_subject ClassSubject[]
 
  @@index([board_id])
}
 
model ClassSubject {
  id         Int @id @default(autoincrement())
  class_id   Int @db.SmallInt
  subject_id Int
 
  class   Class   @relation(fields: [class_id], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subject_id], references: [id], onDelete: Cascade)
 
  user_class_subject   UserClassSubject[]
  school_class_subject SchoolClassSubject[]
  books                Book[]
}
 
model SchoolClassSubject {
  school_id        Int
  class_subject_id Int
 
  school        School       @relation(fields: [school_id], references: [id], onDelete: Cascade)
  class_subject ClassSubject @relation(fields: [class_subject_id], references: [id], onDelete: Cascade)
 
  @@id([school_id, class_subject_id])
}
 
model UserClassSubject {
  user_id          Int
  school_id        Int
  class_subject_id Int
 
  user          User         @relation(fields: [user_id, school_id], references: [id, school_id], onDelete: Cascade)
  class_subject ClassSubject @relation(fields: [class_subject_id], references: [id], onDelete: Cascade)
 
  @@id([user_id, school_id, class_subject_id])
}
 
model User {
  id                   Int
  school_id            Int
  name                 String
  email                String?
  mobile               String?  @db.VarChar(15)
  role                 Role
  password_hash        String
  must_change_password Boolean  @default(true)
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())
 
  school                    School                     @relation(fields: [school_id], references: [id], onDelete: Cascade)
  user_class_subject        UserClassSubject[]
  topic_progress            StudentTopicProgress[]
  page_progress             StudentPageProgress[]
  studentGamificationStates StudentGamificationState[]
 
  @@id([id, school_id])
  @@index([school_id])
}
 
model Document {
  id         String   @id @default(cuid())
  school_id  Int?
  title      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
 
  school School?         @relation(fields: [school_id], references: [id], onDelete: SetNull)
  chunks DocumentChunk[]
 
  @@index([school_id])
}
 
model DocumentChunk {
  id          String @id @default(cuid())
  document_id String
  chunk_index Int
  content     Json
 
  document Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
 
  @@unique([document_id, chunk_index])
  @@index([document_id])
}
 
model Book {
  id               Int    @id @default(autoincrement())
  class_subject_id Int
  title            String
  order_no         Int?
 
  class_subject ClassSubject @relation(fields: [class_subject_id], references: [id], onDelete: Cascade)
  chapters      Chapter[]
 
  @@index([class_subject_id])
}
 
model Topic {
  id         Int    @id @default(autoincrement())
  chapter_id Int
  title      String
  order_no   Int?
 
  chapter          Chapter                @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  page             Page[]
  student_progress StudentTopicProgress[]
 
  @@index([chapter_id])
}
model XpRule {
  activity_type        String @id
  activity_displayname String
  xp_points            Int
}
model StudentGamificationState {
  student_id       Int
  school_id        Int
  total_xp         Int       @default(0)
  current_streak   Int       @default(0) @db.SmallInt
  longest_streak   Int       @default(0) @db.SmallInt
  last_active_date DateTime? @db.Timestamptz
 
  user User @relation(fields: [student_id, school_id], references: [id, school_id], onDelete: Cascade)
 
  @@id([student_id, school_id])
  @@index([school_id])
}
 
model Page {
  id           Int      @id @default(autoincrement())
  topic_id     Int
  page_order   Int?
  content_json Json
  content_html String?
  content_text String?
  is_published Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
 
  topic         Topic                 @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  page_progress StudentPageProgress[]
 
  @@index([topic_id])
  @@index([is_published])
}
 
model StudentTopicProgress {
  student_id Int
  school_id  Int
  topic_id   Int
 
  accuracy         Decimal?
  last_activity_at DateTime?
 
  student User  @relation(fields: [student_id, school_id], references: [id, school_id], onDelete: Cascade)
  topic   Topic @relation(fields: [topic_id], references: [id], onDelete: Cascade)
 
  @@id([student_id, school_id, topic_id])
  @@index([topic_id])
}
 
model StudentPageProgress {
  student_id Int
  school_id  Int
  page_id    Int
 
  is_completed Boolean   @default(false)
  completed_at DateTime?
 
  student User @relation(fields: [student_id, school_id], references: [id, school_id], onDelete: Cascade)
  page    Page @relation(fields: [page_id], references: [id], onDelete: Cascade)
 
  @@id([student_id, school_id, page_id])
  @@index([page_id])
}
 
enum Role {
  student
  teacher
  principal
  admin
  superadmin
}